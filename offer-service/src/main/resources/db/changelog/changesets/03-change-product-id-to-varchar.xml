<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="3" author="comparo-dev">
        <comment>Change product_id from UUID to VARCHAR to support MongoDB ObjectId strings</comment>
        <sql>DELETE FROM offers;</sql>
        <modifyDataType tableName="offers" columnName="product_id" newDataType="VARCHAR(64)"/>
    </changeSet>

</databaseChangeLog>
